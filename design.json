{
  "cds_version": "1.0",
  "name": "ccplugin-git-github",
  "type": "plugin",
  "input_patterns": [
    {
      "type": "slash_command",
      "commands": [
        "/create-pr",
        "/setup-repo",
        "/push-all",
        "/commit-all"
      ]
    }
  ],
  "output_patterns": [
    {
      "type": "terminal_text",
      "max_lines": 20
    },
    {
      "type": "structured_output",
      "description": "Git commits, PR objects via GitHub API"
    }
  ],
  "lifecycle": {
    "preflight": {
      "required_tools": [
        "git",
        "gh"
      ],
      "required_secrets": [
        "GITHUB_TOKEN"
      ],
      "required_mcp": [
        "github",
        "git"
      ]
    }
  },
  "error_handling": {
    "retry_network": true,
    "max_retries": 3
  }
}
